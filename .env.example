# Django
DJANGO_SETTINGS_MODULE=megaindus.settings.dev
SECRET_KEY=django-insecure-change-me-in-production-use-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=megaindus
POSTGRES_USER=megaindus
POSTGRES_PASSWORD=megaindus
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# Frontend
VITE_API_BASE_URL=http://localhost/api
